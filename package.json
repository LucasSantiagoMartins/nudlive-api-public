{
  "name": "nudlive-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:core",
    "build:gateway": "nest build api-gateway",
    "build:core": "nest build core-service",
    "build:realtime": "nest build real-time-service",
    "build:media": "nest build media-live-service",
    "start": "npm run start:core",
    "start:gateway": "nest start api-gateway",
    "start:gateway:dev": "nest start api-gateway --watch",
    "start:core": "nest start core-service",
    "start:core:dev": "nest start core-service --watch",
    "start:realtime": "nest start real-time-service",
    "start:realtime:dev": "nest start real-time-service --watch",
    "start:media": "nest start media-live-service",
    "start:media:dev": "nest start media-live-service --watch",
    "start:prod:gateway": "node dist/apps/api-gateway/main.js",
    "start:prod:core": "node dist/apps/core-service/main.js",
    "start:prod:realtime": "node dist/apps/real-time-service/main.js",
    "start:prod:media": "node dist/apps/media-live-service/main.js",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^10.4.22",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "livekit-server-sdk": "^2.16.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@nudlive/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@nudlive/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
      "^@nudlive/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@nudlive/kafka(|/.*)$": "<rootDir>/libs/kafka/src/$1",
      "^@nudlive/events(|/.*)$": "<rootDir>/libs/events/src/$1"
    }
  }
}